{
  "version": "0.2.0",
  "configurations": [
    // For these launch configurations to work, you need to setup a GODOT4
    // environment variable. On mac or linux, this can be done by adding
    // the following to your .zshrc, .bashrc, or .bash_profile file:
    // export GODOT4="/Applications/Godot.app/Contents/MacOS/Godot"
    {
      "name": "🕹 Debug Game",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${env:GODOT4}",
      // see https://docs.godotengine.org/en/stable/tutorials/editor/command_line_tutorial.html
      //"args": ["--maximized", "--debug"],
      "args": ["--debug"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false
    },
    // Debug the scene that matches the name of the currently open *.cs file
    // (if there's a scene with the same name in the same directory).
    {
      "name": "🎭 Debug Current Scene",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${env:GODOT4}",
      "args": ["${fileDirname}/${fileBasenameNoExtension}.tscn"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false
    },
    // Debug the test scene.
    {
      "name": "🎭 Debug Test Scene",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${env:GODOT4}",
      "args": ["scenes/levels/world_test.tscn"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false
    }
    // {
    //   "name": "🧪 Debug Tests",
